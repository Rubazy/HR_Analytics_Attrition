        cast(WorkLifeBalance as signed)                 as work_life_balance,
        cast(SelfRating as signed)                      as self_rating,
        cast(ManagerRating as signed)                   as manager_rating

    from source
    where PerformanceID is not null
      and EmployeeID is not null
  );
